# SMTP credentials for sending RFP results via email.
# Copy this file to .env and fill in your values.

# The email address used to authenticate with the SMTP server (e.g. your Gmail address)
SMTP_USER=your_email@gmail.com

# The password (or app-specific password) for the SMTP account
SMTP_PASSWORD=your_smtp_password

# OpenAI API key used by the AI agent to filter education-related RFPs
OPENAI_API_KEY=your_openai_api_key
